PREFIX bfo: <http://purl.obolibrary.org/obo/>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX eucn: <https://w3id.org/eucn/>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

bfo:BFO_0000030
    a owl:Class ;
    rdfs:label
        "Objekt"@de ,
        "object"@en ;
    rdfs:isDefinedBy <http://purl.obolibrary.org/obo/bfo/2020/bfo-core.owl> ;
    skos:definition
        "dreidimensionale materielle Entität, die räumlich zusammenhängend ist und kein kontinuierender Teil einer anderen materiellen Entität ist"@de ,
        "three-dimensional material entity that is spatially self-connected and is not a continuant part of any other material entity"@en ;
.

eucn:cnHeadingCode
    a owl:DatatypeProperty ;
    rdfs:label
        "KN-Positionsnummer"@de ,
        "CN heading code"@en ;
    rdfs:range xsd:string ;
    skos:definition
        "Vierstellige (bzw. sechsstellige für Unterpositionen) KN-Positionsnummer, die der OWL-Reasoner aus der Produktklassenzugehörigkeit ableitet; z. B. '2203' für Bier, '220410' für Schaumwein"@de ,
        "four-digit (or six-digit for subheadings) CN heading code inferred by the OWL reasoner from the product class membership; e.g. '2203' for Beer, '220410' for Sparkling Wine"@en ;
.

eucn:core
    a owl:Ontology ;
    rdfs:label
        "EU KN Kern-Ontologie"@de ,
        "EU CN Core Ontology"@en ;
    dcterms:creator <https://github.com/ThHanke> ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:31987R2658> ;
    owl:versionIRI <https://w3id.org/eucn/core/2026/06/08> ;
    owl:versionInfo "EUCN core ontology 2026-06-08" ;
.

eucn:producedBy
    a
        owl:FunctionalProperty ,
        owl:ObjectProperty ;
    rdfs:label
        "hergestellt durch"@de ,
        "produced by"@en ;
    rdfs:range bfo:BFO_0000015 ;
    owl:inverseOf bfo:RO_0002234 ;
    skos:definition
        "Herstellungsprozess, durch den ein Getränk erzeugt wird; verknüpft ein Getränkeindividuum mit seinem benannten Prozesssingleton, zur Unterscheidung zwischen KN-Positionen in Kapitel 22"@de ,
        "production process by which a beverage is made; links a beverage individual to its named process singleton, used to discriminate between CN headings in Chapter 22"@en ;
.

bfo:BFO_0000015
    a owl:Class ;
    rdfs:label
        "Prozess"@de ,
        "process"@en ;
    rdfs:isDefinedBy <http://purl.obolibrary.org/obo/bfo/2020/bfo-core.owl> ;
    skos:definition
        "Entität, die in der Zeit durch Geschehen oder Stattfinden existiert und zeitliche Teile hat"@de ,
        "entity that exists in time by occurring or happening, and that has temporal parts"@en ;
.

bfo:RO_0002234
    a owl:ObjectProperty ;
    rdfs:label
        "hat Ausgabe"@de ,
        "has output"@en ;
    rdfs:isDefinedBy bfo:ro.owl ;
    skos:definition
        "Beziehung zwischen einem Prozess und einer Kontinuant-Entität, die der Prozess ins Dasein bringt"@de ,
        "a relation between a process and a continuant entity that the process brings into existence"@en ;
.
