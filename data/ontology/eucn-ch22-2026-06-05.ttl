PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX eucn: <https://w3id.org/eucn/>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX vann: <http://purl.org/vocab/vann/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

<https://w3id.org/eucn>
    a owl:Ontology ;
    rdfs:label
        "Ontologie der EU-Kombinierten Nomenklatur (KN/TARIC)"@de ,
        "EU Customs Combined Nomenclature Ontology"@en ;
    dcterms:description
        "OWL-2-DL-Ontologie zur Modellierung der Kombinierten Nomenklatur (KN) der EU und des integrierten TARIC-Zolltarifs: Warenpositionen, Zollmaßnahmen und Einreihungshilfen aus EZT-Online. Einreihungspfade aus EZT-Online haben nur Beratungscharakter und stellen kein rechtsverbindliches EU-Instrument dar."@de ,
        "OWL 2 DL ontology modelling the EU Combined Nomenclature (CN) and TARIC integrated tariff: commodity codes, duty measures, and EZT-Online classification guidance. Data extracted from the European Commission CIRCABC TARIC & Quota space. Classification paths sourced from the EZT-Online advisory wizard carry advisory status only and do not constitute legally binding EU instruments."@en ;
    dcterms:issued "2026-06-05"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:source
        <https://circabc.europa.eu/ui/group/0e5f18c2-4b2f-42e9-aed4-dfe50ae1263b> ,
        <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:31987R2658> ;
    dcterms:title
        "Ontologie der EU-Kombinierten Nomenklatur (KN/TARIC)"@de ,
        "EU Customs Combined Nomenclature Ontology"@en ;
    vann:preferredNamespacePrefix "eucn" ;
    vann:preferredNamespaceUri "https://w3id.org/eucn/" ;
    owl:versionIRI <https://w3id.org/eucn/2026/06/05> ;
    owl:versionInfo "TARIC extract 2026-06-05" ;
.

eucn:Heading
    a owl:Class ;
    rdfs:label
        "Position"@de ,
        "Heading"@en ;
    skos:definition
        "vierstellige Unterteilung der Nomenklatur des Harmonisierten Systems, die eine bestimmte Warengruppe innerhalb eines Kapitels durch weitere Differenzierung nach Material, Verarbeitungsstufe oder Verwendungszweck identifiziert"@de ,
        "four-digit subdivision of the Harmonized System nomenclature that identifies a specific group of goods within a chapter by further differentiating on material, process, or use"@en ;
.

eucn:TARICCode
    a owl:Class ;
    rdfs:label
        "TARIC-Code"@de ,
        "TARIC Code"@en ;
    rdfs:subClassOf eucn:CNCode ;
    skos:definition
        "Zehnstellige Erweiterung eines KN-Codes im Integrierten Zolltarif der Europäischen Gemeinschaften, die die anwendbaren Regelungsmaßnahmen auf der detailliertesten Warenebene festlegt"@de ,
        "ten-digit extension of a CN code within the Integrated Tariff of the European Communities that specifies the applicable regulatory measures at the most granular commodity level"@en ;
.

eucn:answerText
    a owl:DatatypeProperty ;
    rdfs:label
        "Antworttext"@de ,
        "answer text"@en ;
    rdfs:range xsd:string ;
    skos:definition
        "textliche Formulierung der Antwortoption, die bei Auswahl an einem übergeordneten Einreihungsknoten den Übergang zu diesem Einreihungsknoten im sequenziellen Einreihungsverfahren bestimmt"@de ,
        "textual formulation of the answer option that, when selected at a parent classification node, determines the transition to this classification node in the sequential classification procedure"@en ;
.

eucn:belongsToChapter
    a owl:ObjectProperty ;
    rdfs:label
        "gehört zu Kapitel"@de ,
        "belongs to chapter"@en ;
    rdfs:domain eucn:CNCode ;
    rdfs:range eucn:Chapter ;
    skos:definition
        "Beziehung zwischen einem KN-Code und dem zweistelligen Kapitel des Harmonisierten Systems, in dessen Nomenklaturgeltungsbereich der Code fällt"@de ,
        "relation between a CN code and the two-digit Harmonized System chapter in whose nomenclature scope the code is situated"@en ;
.

eucn:classifiesAs
    a owl:ObjectProperty ;
    rdfs:label
        "wird eingereiht als"@de ,
        "classifies as"@en ;
    rdfs:domain eucn:ClassificationNode ;
    rdfs:range eucn:CNCode ;
    skos:definition
        "Beziehung zwischen einem terminalen Einreihungsknoten und dem KN-Code, unter den Waren nach Abschluss des sequenziellen Einreihungsverfahrens, das am Wurzelknoten beginnt, eingereiht werden"@de ,
        "relation between a terminal classification node and the CN code to which goods are assigned upon completion of the sequential classification procedure initiated at the root node"@en ;
.

eucn:codeString
    a owl:DatatypeProperty ;
    rdfs:label
        "Codenummer"@de ,
        "code string"@en ;
    rdfs:range xsd:string ;
    skos:definition
        "Ziffernfolge, die eine Nomenklaturstelle ohne Trennzeichen eindeutig identifiziert, gebildet durch Aneinanderreihung der numerischen Segmente des Codes, z. B. '22042100' für KN-Code 2204 21 00"@de ,
        "digit string uniquely identifying a nomenclature position without separating punctuation, derived by concatenating the numeric segments of the code, e.g. '22042100' for CN code 2204 21 00"@en ;
.

eucn:description
    a owl:DatatypeProperty ;
    rdfs:label
        "Warenbezeichnung"@de ,
        "description"@en ;
    rdfs:range xsd:string ;
    skos:definition
        "amtliche Warenbezeichnung, wie sie im Rechtstext der Kombinierten Nomenklatur festgelegt ist, in einer bestimmten natürlichen Sprache und mit rechtlicher Wirkung innerhalb der EU-Zolleinreihung"@de ,
        "official textual designation of a commodity as established in the legal text of the Combined Nomenclature, expressed in a specified natural language and carrying legal force within EU customs classification"@en ;
.

eucn:dutyAmount
    a owl:DatatypeProperty ;
    rdfs:label
        "Zollbetrag"@de ,
        "duty amount"@en ;
    rdfs:range xsd:decimal ;
    skos:definition
        "numerischer Wert des Zoll- oder Abgabensatzes im Rahmen einer TARIC-Maßnahme"@de ,
        "numeric value of the duty or charge rate applicable under a TARIC measure"@en ;
.

eucn:dutyRate
    a owl:DatatypeProperty ;
    rdfs:label
        "Zollsatz"@de ,
        "duty rate"@en ;
    rdfs:range xsd:string ;
    skos:definition
        "textliche Darstellung des Zoll- oder Abgabensatzes, der im Rahmen einer TARIC-Maßnahme gilt, wie in den TARIC-Massendaten veröffentlicht, bestehend aus einem numerischen Wert und einer Maßeinheit, z. B. '12,0 %' oder '32,0 EUR/hl'"@de ,
        "textual expression of the duty or charge rate applicable under a TARIC measure as published in the TARIC bulk data, combining a numeric value with a unit of measurement, e.g. '12.0 %' or '32.0 EUR/hl'"@en ;
.

eucn:geographicScope
    a owl:DatatypeProperty ;
    rdfs:label
        "geografischer Geltungsbereich"@de ,
        "geographic scope"@en ;
    rdfs:range xsd:string ;
    skos:definition
        "Kennung des Landes oder der Ländergruppe, deren Ursprungswaren einer TARIC-Maßnahme unterliegen, ausgedrückt als ISO 3166-1-Alpha-2-Ländercode oder als TARIC-Gruppencode, z. B. '1011' für ERGA OMNES (alle Drittländer)"@de ,
        "identifier of the country or country group to whose originating goods a TARIC measure applies, expressed as an ISO 3166-1 alpha-2 country code or a TARIC-assigned group code, e.g. '1011' for ERGA OMNES (all third countries)"@en ;
.

eucn:hasAnswer
    a owl:ObjectProperty ;
    rdfs:label
        "hat Antwort"@de ,
        "has answer"@en ;
    rdfs:domain eucn:ClassificationNode ;
    rdfs:range eucn:ClassificationNode ;
    skos:definition
        "Beziehung zwischen einem Einreihungsknoten und einem nachfolgenden Einreihungsknoten, der durch Auswahl einer bestimmten Antwort auf die am Ausgangsknoten gestellte unterscheidende Frage erreicht wird"@de ,
        "relation between a classification node and a subsequent classification node reached by selecting a particular answer to the discriminating question posed at the source node"@en ;
.

eucn:hasMeasure
    a owl:ObjectProperty ;
    rdfs:label
        "hat Maßnahme"@de ,
        "has measure"@en ;
    rdfs:domain eucn:CNCode ;
    rdfs:range eucn:TARICMeasure ;
    skos:definition
        "Beziehung zwischen einem KN-Code und einer TARIC-Maßnahme, deren Regelungsbedingungen für Waren gelten, die unter diesen KN-Code eingereiht sind"@de ,
        "relation between a CN code and a TARIC measure under which goods classified by that CN code are subject to the regulatory conditions specified by the measure"@en ;
.

