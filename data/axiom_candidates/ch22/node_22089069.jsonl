{"candidate_id":"501394c3356857b6f37a34cad5c471d7b7b3988f4985010aea1c8e85da4a7b15","cn_code":"22089069","new_classes":[{"iri_local_name":"OtherSpiritousBeverageMixedOrWithAdditionsQuality","label_en":"Other spirituous beverage (mixed or with additions) quality","label_de":"Qualität anderer alkoholhaltiger Getränke (gemischt oder mit Zusätzen)","definition_en":"Quality borne by spirituous beverages that do not fall under any of the specifically named categories (arrack, rum, whisky, vodka, gin, liqueur, plum/pear/cherry spirit, other fruit spirit) classified under CN 2208 90 33–56, and that may include added aerated water (e.g. whisky-soda), tea with alcohol, mixtures of spirituous beverages together, or mixtures of spirituous beverages with fruit or vegetable juices. Corresponds to the residual 'other' category at CN 2208 90 69.","bfo_parent_iri":"http://purl.obolibrary.org/obo/BFO_0000019","class_type":"quality"}],"new_properties":[],"restrictions":[{"owl_class_iri":"https://w3id.org/eucn/OtherSpiritousBeverageMixedOrWithAdditionsQuality","restriction_type":"complement","property_iri":"https://w3id.org/eucn/producedBy","value":"https://w3id.org/eucn/ArrackSpiritQuality","facet":null},{"owl_class_iri":"https://w3id.org/eucn/OtherSpiritousBeverageMixedOrWithAdditionsQuality","restriction_type":"complement","property_iri":"https://w3id.org/eucn/producedBy","value":"https://w3id.org/eucn/RumSugarCaneSpiritOrganolepticQuality","facet":null},{"owl_class_iri":"https://w3id.org/eucn/OtherSpiritousBeverageMixedOrWithAdditionsQuality","restriction_type":"complement","property_iri":"https://w3id.org/eucn/producedBy","value":"https://w3id.org/eucn/WhiskyQuality","facet":null},{"owl_class_iri":"https://w3id.org/eucn/OtherSpiritousBeverageMixedOrWithAdditionsQuality","restriction_type":"complement","property_iri":"https://w3id.org/eucn/producedBy","value":"https://w3id.org/eucn/WodkaQuality","facet":null},{"owl_class_iri":"https://w3id.org/eucn/OtherSpiritousBeverageMixedOrWithA