@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix eucn: <https://w3id.org/eucn/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

bfo:BFO_0000051 a owl:ObjectProperty ;
    rdfs:label "hat Teil"@de,
        "has part"@en ;
    rdfs:domain bfo:BFO_0000030 ;
    rdfs:isDefinedBy <http://purl.obolibrary.org/obo/bfo/2020/bfo-core.owl> ;
    rdfs:range bfo:BFO_0000030 ;
    skos:definition "a core relation that holds between a whole and its parts"@en .

bfo:BFO_0000066 a owl:ObjectProperty ;
    rdfs:label "findet statt in"@de,
        "occurs in"@en ;
    rdfs:domain bfo:BFO_0000015 ;
    rdfs:isDefinedBy <http://purl.obolibrary.org/obo/bfo/2020/bfo-core.owl> ;
    rdfs:range bfo:BFO_0000029 ;
    skos:definition "a relation between an occurrent (process) and an independent continuant (site) that is the spatial region in which the process takes place"@en .

<https://w3id.org/eucn> a owl:Ontology ;
    rdfs:label "Ontologie der EU-Kombinierten Nomenklatur (KN/TARIC)"@de,
        "EU Customs Combined Nomenclature Ontology"@en ;
    dcterms:description "OWL-2-DL-Ontologie zur Modellierung der Kombinierten Nomenklatur (KN) der EU und des integrierten TARIC-Zolltarifs: Warenpositionen, Zollmaßnahmen und Einreihungshilfen aus EZT-Online. Einreihungspfade aus EZT-Online haben nur Beratungscharakter und stellen kein rechtsverbindliches EU-Instrument dar."@de,
        "OWL 2 DL ontology modelling the EU Combined Nomenclature (CN) and TARIC integrated tariff: commodity codes, duty measures, and EZT-Online classification guidance. Data extracted from the European Commission CIRCABC TARIC & Quota space. Classification paths sourced from the EZT-Online advisory wizard carry advisory status only and do not constitute legally binding EU instruments."@en ;
    dcterms:issued "2026-06-10"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:source <https://circabc.europa.eu/ui/group/0e5f18c2-4b2f-42e9-aed4-dfe50ae1263b>,
        <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:31987R2658> ;
    dcterms:title "Ontologie der EU-Kombinierten Nomenklatur (KN/TARIC)"@de,
        "EU Customs Combined Nomenclature Ontology"@en ;
    vann:preferredNamespacePrefix "eucn" ;
    vann:preferredNamespaceUri "https://w3id.org/eucn/" ;
    owl:versionIRI <https://w3id.org/eucn/2026/06/10> ;
    owl:versionInfo "TARIC extract 2026-06-10" .

eucn:Footnote a owl:Class ;
    rdfs:label "Fußnote"@de,
        "Footnote"@en ;
    skos:definition "rechtliche Anmerkung, identifiziert durch einen TN-Präfix-Code, die den Geltungsbereich einer TARIC-Maßnahme oder Nomenklaturstelle qualifiziert oder einschränkt"@de,
        "legal annotation identified by a TN-prefix code that qualifies or restricts the scope of a TARIC measure or nomenclature position"@en .

eucn:LargeContainer a owl:Class ;
    rdfs:label "Großbehälter (≥ 2 L)"@de,
        "large container (≥ 2 L)"@en ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( eucn:Packaging [ a owl:Restriction ;
                        owl:onProperty bfo:RO_0000086 ;
                        owl:someValuesFrom [ a owl:Class ;
                                owl:intersectionOf ( eucn:Volume [ a owl:Restriction ;
                                            owl:onProperty eucn:inLitres ;
                                            owl:someValuesFrom [ a rdfs:Datatype ;
                                                    owl:onDatatype xsd:decimal ;
                                                    owl:withRestrictions ( [ xsd:minInclusive 2.0 ] ) ] ] ) ] ] ) ] ;
    skos:definition "Verpackung, deren Volumeneigenschaft einen Wert von mindestens 2 Litern hat."@de,
        "Packaging whose Volume quality has a value of at least 2 litres."@en .

eucn:SmallContainer a owl:Class ;
    rdfs:label "Kleinbehälter (< 2 L)"@de,
        "small container (< 2 L)"@en ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( eucn:Packaging [ a owl:Restriction ;
                        owl:onProperty bfo:RO_0000086 ;
                        owl:someValuesFrom [ a owl:Class ;
                                owl:intersectionOf ( eucn:Volume [ a owl:Restriction ;
                                            owl:onProperty eucn:inLitres ;
                                            owl:someValuesFrom [ a rdfs:Datatype ;
                                                    owl:onDatatype xsd:decimal ;
                                                    owl:withRestrictions ( [ xsd:maxExclusive 2.0 ] ) ] ] ) ] ] ) ] ;
    skos:definition "Verpackung, deren Volumeneigenschaft einen Wert von weniger als 2 Litern hat."@de,
        "Packaging whose Volume quality has a value of less than 2 litres."@en .

eucn:TARICCode a owl:Class ;
    rdfs:label "TARIC-Code"@de,
        "TARIC Code"@en ;
    rdfs:subClassOf eucn:CNCode ;
    skos:definition "Zehnstellige Erweiterung eines KN-Codes im Integrierten Zolltarif der Europäischen Gemeinschaften, die die anwendbaren Regelungsmaßnahmen auf der detailliertesten Warenebene festlegt"@de,
        "ten-digit extension of a CN code within the Integrated Tariff of the European Communities that specifies the applicable regulatory measures at the most granular commodity level"@en .

eucn:TARICSubheading a owl:Class ;
    rdfs:label "TARIC-Unterposition"@de,
        "TARIC Subheading"@en ;
    rdfs:subClassOf eucn:CNCode ;
    skos:definition "sechsstellige Unterteilung des Harmonisierten Systems, die Waren innerhalb einer vierstelligen Position weiter differenziert"@de,
        "six-digit subdivision of the Harmonized System nomenclature that further differentiates goods within a four-digit heading"@en .

eucn:additionalCodeValue a owl:DatatypeProperty ;
    rdfs:label "Zusatzcode-Wert"@de,
        "additional code value"@en ;
    rdfs:range xsd:string ;
    skos:definition "vierstellige TARIC-Zusatzcode-Zeichenfolge, z. B. 'X301' für die Verbrauchsteuerkategorie Alkoholarme Getränke"@de,
        "four-character TARIC additional code string, e.g. 'X301' for the low-alcohol excise category"@en .

eucn:alcoholByVolumePercent a owl:DatatypeProperty ;
    rdfs:label "Alkoholgehalt in Volumenprozent"@de,
        "alcohol by volume percent"@en ;
    rdfs:range xsd:decimal ;
    skos:definition "Alkoholgehalt eines Getränks, ausgedrückt als Volumenprozent, zur Unterscheidung zwischen den KN-Positionen 2201–2208 in Kapitel 22"@de,
        "alcohol content of a beverage expressed as a percentage of volume, used to discriminate between CN headings 2201–2208 in Chapter 22"@en .

eucn:answerText a owl:DatatypeProperty ;
    rdfs:label "Antworttext"@de,
        "answer text"@en ;
    rdfs:range xsd:string ;
    skos:definition "textliche Formulierung der Antwortoption, die bei Auswahl an einem übergeordneten Einreihungsknoten den Übergang zu diesem Einreihungsknoten im sequenziellen Einreihungsverfahren bestimmt"@de,
        "textual formulation of the answer option that, when selected at a parent classification node, determines the transition to this classification node in the sequential classification procedure"@en .

eucn:areaCode a owl:DatatypeProperty ;
    rdfs:label "Gebietskennung"@de,
        "area code"@en ;
    rdfs:range xsd:string ;
    skos:definition "ISO 3166-1 Alpha-2-Ländercode oder TARIC-Gruppencode zur Identifizierung eines geografischen Gebiets, z. B. 'DE' für Deutschland oder '1011' für ERGA OMNES"@de,
        "ISO 3166-1 alpha-2 country code or TARIC-assigned group code identifying a geographic area, e.g. 'DE' for Germany or '1011' for ERGA OMNES"@en .

eucn:belongsToChapter a owl:ObjectProperty ;
    rdfs:label "gehört zu Kapitel"@de,
        "belongs to chapter"@en ;
    rdfs:domain eucn:CNCode ;
    rdfs:range eucn:Chapter ;
    skos:definition "Beziehung zwischen einem KN-Code und dem zweistelligen Kapitel des Harmonisierten Systems, in dessen Nomenklaturgeltungsbereich der Code fällt"@de,
        "relation between a CN code and the two-digit Harmonized System chapter in whose nomenclature scope the code is situated"@en .

eucn:belongsToHeading a owl:ObjectProperty ;
    rdfs:label "gehört zu Position"@de,
        "belongs to heading"@en ;
    rdfs:domain eucn:CNCode ;
    rdfs:range eucn:Heading ;
    skos:definition "Beziehung zwischen einem KN-Code und der vierstelligen Position, die er unterteilt"@de,
        "relation between a CN code and the four-digit heading that it subdivides"@en .

eucn:belongsToSection a owl:ObjectProperty ;
    rdfs:label "gehört zu Abschnitt"@de,
        "belongs to section"@en ;
    rdfs:domain eucn:Chapter ;
    rdfs:range eucn:TARICSection ;
    skos:definition "Beziehung zwischen einem Kapitel und dem TARIC-Abschnitt mit römischer Nummerierung, der es enthält"@de,
        "relation between a chapter and the Roman-numeral TARIC section that contains it"@en .

eucn:classifiesAs a owl:ObjectProperty ;
    rdfs:label "wird eingereiht als"@de,
        "classifies as"@en ;
    rdfs:domain eucn:ClassificationNode ;
    rdfs:range eucn:CNCode ;
    skos:definition "Beziehung zwischen einem terminalen Einreihungsknoten und dem KN-Code, unter den Waren nach Abschluss des sequenziellen Einreihungsverfahrens, das am Wurzelknoten beginnt, eingereiht werden"@de,
        "relation between a terminal classification node and the CN code to which goods are assigned upon completion of the sequential classification procedure initiated at the root node"@en .

eucn:cnHeadingCode a owl:DatatypeProperty ;
    rdfs:label "KN-Positionsnummer"@de,
        "CN heading code"@en ;
    rdfs:range xsd:string ;
    skos:definition "Vierstellige (bzw. sechsstellige für Unterpositionen) KN-Positionsnummer, die der OWL-Reasoner aus der Produktklassenzugehörigkeit ableitet; z. B. '2203' für Bier, '220410' für Schaumwein"@de,
        "four-digit (or six-digit for subheadings) CN heading code inferred by the OWL reasoner from the product class membership; e.g. '2203' for Beer, '220410' for Sparkling Wine"@en .

eucn:codeString a owl:DatatypeProperty ;
    rdfs:label "Codenummer"@de,
        "code string"@en ;
    rdfs:range xsd:string ;
    skos:definition "Ziffernfolge, die eine Nomenklaturstelle ohne Trennzeichen eindeutig identifiziert, gebildet durch Aneinanderreihung der numerischen Segmente des Codes, z. B. '22042100' für KN-Code 2204 21 00"@de,
        "digit string uniquely identifying a nomenclature position without separating punctuation, derived by concatenating the numeric segments of the code, e.g. '22042100' for CN code 2204 21 00"@en .

eucn:conditionCode a owl:DatatypeProperty ;
    rdfs:label "Bedingungscode"@de,
        "condition code"@en ;
    rdfs:range xsd:string ;
    skos:definition "einstelliger Code zur Identifizierung des Typs einer Maßnahmebedingung, z. B. 'B' für Dokumentenvorlage oder 'E' für Mengenschwellenwert"@de,
        "single-character code identifying the type of a measure condition, e.g. 'B' for document presentation or 'E' for quantity threshold"@en .

eucn:core a owl:Ontology ;
    rdfs:label "EU KN Kern-Ontologie"@de,
        "EU CN Core Ontology"@en ;
    dcterms:creator <https://github.com/ThHanke> ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:31987R2658> ;
    owl:versionIRI <https://w3id.org/eucn/core/2026/06/10> ;
    owl:versionInfo "EUCN core ontology 2026-06-10" .

eucn:description a owl:DatatypeProperty ;
    rdfs:label "Warenbezeichnung"@de,
        "description"@en ;
    rdfs:range xsd:string ;
    skos:definition "amtliche Warenbezeichnung, wie sie im Rechtstext der Kombinierten Nomenklatur festgelegt ist, in einer bestimmten natürlichen Sprache und mit rechtlicher Wirkung innerhalb der EU-Zolleinreihung"@de,
        "official textual designation of a commodity as established in the legal text of the Combined Nomenclature, expressed in a specified natural language and carrying legal force within EU customs classification"@en .

eucn:dutyAmount a owl:DatatypeProperty ;
    rdfs:label "Zollbetrag"@de,
        "duty amount"@en ;
    rdfs:range xsd:decimal ;
    skos:definition "numerischer Wert des Zoll- oder Abgabensatzes im Rahmen einer TARIC-Maßnahme"@de,
        "numeric value of the duty or charge rate applicable under a TARIC measure"@en .

eucn:dutyRate a owl:DatatypeProperty ;
    rdfs:label "Zollsatz"@de,
        "duty rate"@en ;
    rdfs:range xsd:string ;
    skos:definition "textliche Darstellung des Zoll- oder Abgabensatzes, der im Rahmen einer TARIC-Maßnahme gilt, wie in den TARIC-Massendaten veröffentlicht, bestehend aus einem numerischen Wert und einer Maßeinheit, z. B. '12,0 %' oder '32,0 EUR/hl'"@de,
        "textual expression of the duty or charge rate applicable under a TARIC measure as published in the TARIC bulk data, combining a numeric value with a unit of measurement, e.g. '12.0 %' or '32.0 EUR/hl'"@en .

eucn:footnoteCode a owl:DatatypeProperty ;
    rdfs:label "Fußnotencode"@de,
        "footnote code"@en ;
    rdfs:range xsd:string ;
    skos:definition "TN-Präfix-Code zur eindeutigen Identifizierung einer TARIC-Fußnote, z. B. 'TN207'"@de,
        "TN-prefix code uniquely identifying a TARIC footnote, e.g. 'TN207'"@en .

eucn:geographicScope a owl:DatatypeProperty ;
    rdfs:label "geografischer Geltungsbereich"@de,
        "geographic scope"@en ;
    rdfs:range xsd:string ;
    skos:definition "Kennung des Landes oder der Ländergruppe, deren Ursprungswaren einer TARIC-Maßnahme unterliegen, ausgedrückt als ISO 3166-1-Alpha-2-Ländercode oder als TARIC-Gruppencode, z. B. '1011' für ERGA OMNES (alle Drittländer)"@de,
        "identifier of the country or country group to whose originating goods a TARIC measure applies, expressed as an ISO 3166-1 alpha-2 country code or a TARIC-assigned group code, e.g. '1011' for ERGA OMNES (all third countries)"@en .

eucn:hasAdditionalCode a owl:ObjectProperty ;
    rdfs:label "hat Zusatzcode"@de,
        "has additional code"@en ;
    rdfs:domain eucn:TARICMeasure ;
    rdfs:range eucn:AdditionalCode ;
    skos:definition "Beziehung zwischen einer TARIC-Maßnahme und dem Zusatzcode, der die Waren, auf die sie zutrifft, weiter qualifiziert"@de,
        "relation between a TARIC measure and the additional code that further qualifies the goods it applies to"@en .

eucn:hasAnswer a owl:ObjectProperty ;
    rdfs:label "hat Antwort"@de,
        "has answer"@en ;
    rdfs:domain eucn:ClassificationNode ;
    rdfs:range eucn:ClassificationNode ;
    skos:definition "Beziehung zwischen einem Einreihungsknoten und einem nachfolgenden Einreihungsknoten, der durch Auswahl einer bestimmten Antwort auf die am Ausgangsknoten gestellte unterscheidende Frage erreicht wird"@de,
        "relation between a classification node and a subsequent classification node reached by selecting a particular answer to the discriminating question posed at the source node"@en .

eucn:hasCertificate a owl:ObjectProperty ;
    rdfs:label "hat Zertifikat"@de,
        "has certificate"@en ;
    rdfs:domain eucn:MeasureCondition ;
    rdfs:range eucn:Certificate ;
    skos:definition "Beziehung zwischen einer Maßnahmebedingung und dem Zertifikatsdokument, das zu ihrer Erfüllung erforderlich ist"@de,
        "relation between a measure condition and the certificate document required to satisfy it"@en .

eucn:hasCondition a owl:ObjectProperty ;
    rdfs:label "hat Bedingung"@de,
        "has condition"@en ;
    rdfs:domain eucn:TARICMeasure ;
    rdfs:range eucn:MeasureCondition ;
    skos:definition "Beziehung zwischen einer TARIC-Maßnahme und einer von ihr auferlegten Maßnahmebedingung"@de,
        "relation between a TARIC measure and a measure condition it imposes"@en .

eucn:hasDutyExpression a owl:ObjectProperty ;
    rdfs:label "hat Zollausdruck"@de,
        "has duty expression"@en ;
    rdfs:domain eucn:TARICMeasure ;
    rdfs:range eucn:DutyExpression ;
    skos:definition "Beziehung zwischen einer TARIC-Maßnahme und ihrer Zollausdruck-Instanz"@de,
        "relation between a TARIC measure and its duty expression individual"@en .

eucn:hasFootnote a owl:ObjectProperty ;
    rdfs:label "hat Fußnote"@de,
        "has footnote"@en ;
    skos:definition "Beziehung zwischen einer TARIC-Maßnahme oder einem KN-Code und einer Fußnote, die deren Geltungsbereich qualifiziert"@de,
        "relation between a TARIC measure or CN code and a footnote that qualifies its scope"@en .

eucn:hasGeographicArea a owl:ObjectProperty ;
    rdfs:label "hat geografisches Gebiet"@de,
        "has geographic area"@en ;
    rdfs:domain eucn:TARICMeasure ;
    rdfs:range eucn:GeographicArea ;
    skos:definition "Beziehung zwischen einer TARIC-Maßnahme und der geografischen Gebiet-Instanz, die ihren territorialen Geltungsbereich definiert"@de,
        "relation between a TARIC measure and the geographic area individual defining its territorial scope"@en .

eucn:hasMeasure a owl:ObjectProperty ;
    rdfs:label "hat Maßnahme"@de,
        "has measure"@en ;
    rdfs:domain eucn:CNCode ;
    rdfs:range eucn:TARICMeasure ;
    skos:definition "Beziehung zwischen einem KN-Code und einer TARIC-Maßnahme, deren Regelungsbedingungen für Waren gelten, die unter diesen KN-Code eingereiht sind"@de,
        "relation between a CN code and a TARIC measure under which goods classified by that CN code are subject to the regulatory conditions specified by the measure"@en .

eucn:hasMeasureType a owl:ObjectProperty ;
    rdfs:label "hat Maßnahmetyp"@de,
        "has measure type"@en ;
    rdfs:domain eucn:TARICMeasure ;
    rdfs:range eucn:MeasureType ;
    skos:definition "Beziehung zwischen einer TARIC-Maßnahme und ihrer Regelungskategorie-Instanz"@de,
        "relation between a TARIC measure and its regulatory category individual"@en .

eucn:hasMeasurementUnit a owl:ObjectProperty ;
    rdfs:label "hat Maßeinheit"@de,
        "has measurement unit"@en ;
    rdfs:range eucn:MeasurementUnit ;
    skos:definition "Beziehung zwischen einem Zollausdruck oder einer Maßnahmebedingung und der für den Satz oder Schwellenwert verwendeten Maßeinheit"@de,
        "relation between a duty expression or measure condition and the unit of measurement used for the rate or threshold"@en .

eucn:hasRegulation a owl:ObjectProperty ;
    rdfs:label "hat Verordnung"@de,
        "has regulation"@en ;
    rdfs:domain eucn:TARICMeasure ;
    rdfs:range eucn:Regulation ;
    skos:definition "Beziehung zwischen einer TARIC-Maßnahme und dem EU-Rechtsakt, der sie erlassen hat"@de,
        "relation between a TARIC measure and the EU legal act that created it"@en .

eucn:isCarbonated a owl:DatatypeProperty ;
    rdfs:label "ist kohlensäurehaltig"@de,
        "is carbonated"@en ;
    rdfs:range xsd:boolean ;
    skos:definition "boolesches Merkmal, das angibt, ob ein Getränk mit Kohlensäure versetzt (schäumend) statt still ist, zur Unterscheidung zwischen den KN-Unterpositionen 2204 10 und 2204 21/29"@de,
        "boolean flag indicating whether a beverage is carbonated (sparkling) rather than still, used to discriminate between CN subheadings 2204 10 (sparkling) and 2204 21/29 (still)"@en .

eucn:isDenatured a owl:DatatypeProperty ;
    rdfs:label "ist vergällt"@de,
        "is denatured"@en ;
    rdfs:range xsd:boolean ;
    skos:definition "boolesches Merkmal, das angibt, ob Ethylalkohol durch Zusatz von Stoffen vergällt wurde, die ihn für den menschlichen Genuss ungeeignet machen, zur Unterscheidung zwischen den KN-Unterpositionen 2207 10 (unvergällt) und 2207 20 (vergällt)"@de,
        "boolean flag indicating whether ethyl alcohol has been denatured by addition of substances rendering it unfit for human consumption, used to discriminate between CN subheadings 2207 10 (undenatured) and 2207 20 (denatured)"@en .

eucn:maxContainerVolumeL a owl:DatatypeProperty ;
    rdfs:label "maximales Behältervolumen in Litern"@de,
        "maximum container volume in litres"@en ;
    rdfs:range xsd:decimal ;
    skos:definition "Nennvolumen in Litern des Behälters, in dem ein Getränk aufgemacht ist, zur Unterscheidung zwischen den KN-Unterpositionen 2204 21 (≤ 2 L) und 2204 29 (> 2 L)"@de,
        "nominal volume in litres of the container in which a beverage is presented, used to discriminate between CN subheadings 2204 21 (≤ 2 L) and 2204 29 (> 2 L)"@en .

eucn:measureTypeCode a owl:DatatypeProperty ;
    rdfs:label "Maßnahmetyp-Code"@de,
        "measure type code"@en ;
    rdfs:range xsd:string ;
    skos:definition "numerische Zeichenfolge zur Identifizierung eines TARIC-Maßnahmetyps, z. B. '103' für Drittlandszollsatz oder '142' für Zollpräferenz"@de,
        "numeric string identifying a TARIC measure type, e.g. '103' for third-country duty or '142' for tariff preference"@en .

eucn:measureTypeId a owl:DatatypeProperty ;
    rdfs:label "Maßnahmetyp-Kennung"@de,
        "measure type ID"@en ;
    rdfs:range xsd:string ;
    skos:definition "von TARIC zugewiesener numerischer Code, der die Regelungskategorie einer Maßnahme bezeichnet und zwischen Zollarten, Verboten, Aussetzungen, Kontingenten und Genehmigungspflichten unterscheidet, z. B. '103' für den Meistbegünstigungs-Wertzollsatz"@de,
        "numeric code assigned by TARIC that designates the regulatory category of a measure, distinguishing between duty types, prohibitions, suspensions, quotas, and licence requirements, e.g. '103' for Most Favoured Nation ad-valorem duty"@en .

eucn:measureTypeSeries a owl:DatatypeProperty ;
    rdfs:label "Maßnahmetyp-Reihe"@de,
        "measure type series"@en ;
    rdfs:range xsd:string ;
    skos:definition "einstelliger Reihenbezeichner (A–Q), der verwandte TARIC-Maßnahmetypen nach ihrer Regelungsfunktion zusammenfasst"@de,
        "single-character series identifier (A–Q) grouping related TARIC measure types by regulatory function"@en .

eucn:producedBy a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "hergestellt durch"@de,
        "produced by"@en ;
    rdfs:range bfo:BFO_0000015 ;
    owl:inverseOf bfo:RO_0002234 ;
    skos:definition "Herstellungsprozess, durch den ein Getränk erzeugt wird; verknüpft ein Getränkeindividuum mit seinem benannten Prozesssingleton, zur Unterscheidung zwischen KN-Positionen in Kapitel 22"@de,
        "production process by which a beverage is made; links a beverage individual to its named process singleton, used to discriminate between CN headings in Chapter 22"@en .

eucn:questionText a owl:DatatypeProperty ;
    rdfs:label "Fragetext"@de,
        "question text"@en ;
    rdfs:range xsd:string ;
    skos:definition "textliche Formulierung der unterscheidenden Frage, die an einem Einreihungsknoten des EZT-Online-Assistenten gestellt wird, in einer bestimmten natürlichen Sprache, zur Führung des Einreihenden zur zutreffenden Nomenklaturstelle"@de,
        "textual formulation of the discriminating question posed at a classification node in the EZT-Online wizard, expressed in a specified natural language, used to guide the classifier toward the applicable nomenclature branch"@en .

eucn:quotaOrderNumber a owl:DatatypeProperty ;
    rdfs:label "Kontingentordnungsnummer"@de,
        "quota order number"@en ;
    rdfs:range xsd:string ;
    skos:definition "sechsstellige Kontingentordnungsnummer, die einen Präferenzzollsatz im Rahmen einer TARIC-Tarifkontingenmaßnahme bedingt"@de,
        "six-digit quota order number gating a preferential tariff rate under a TARIC tariff quota measure"@en .

eucn:regulationId a owl:DatatypeProperty ;
    rdfs:label "Verordnungskennung"@de,
        "regulation ID"@en ;
    rdfs:range xsd:string ;
    skos:definition "Kennung der EU-Verordnung oder der maßnahmenerzeugenden Verordnung, die eine TARIC-Maßnahme erlassen oder zuletzt geändert hat"@de,
        "identifier of the EU regulation or measure generating regulation that created or last amended a TARIC measure"@en .

eucn:regulationRef a owl:DatatypeProperty ;
    rdfs:label "Verordnungsreferenz"@de,
        "regulation reference"@en ;
    rdfs:range xsd:string ;
    skos:definition "Amtsblatt-Fundstelle oder Verordnungscode des einer TARIC-Maßnahme zugrunde liegenden Rechtsakts, z. B. 'R2658/87'"@de,
        "official journal reference or regulation code of the legal act underlying a TARIC measure, e.g. 'R2658/87'"@en .

eucn:validityEnd a owl:DatatypeProperty ;
    rdfs:label "Gültigkeitsende"@de,
        "validity end"@en ;
    rdfs:range xsd:date ;
    skos:definition "Datum, an dem eine TARIC-Maßnahme außer Kraft tritt; fehlt, wenn die Maßnahme kein festgelegtes Ablaufdatum hat"@de,
        "date on which a TARIC measure ceases to be in force; absent when the measure has no fixed expiry"@en .

eucn:validityStart a owl:DatatypeProperty ;
    rdfs:label "Gültigkeitsbeginn"@de,
        "validity start"@en ;
    rdfs:range xsd:date ;
    skos:definition "Datum, ab dem eine TARIC-Maßnahme in Kraft tritt"@de,
        "date from which a TARIC measure is in force"@en .

bfo:BFO_0000003 a owl:Class ;
    rdfs:label "Okkurrent"@de,
        "occurrent"@en ;
    rdfs:isDefinedBy <http://purl.obolibrary.org/obo/bfo/2020/bfo-core.owl> ;
    skos:definition "Entität, die sich in der Zeit entfaltet oder die momentane Grenze einer solchen Entität ist"@de,
        "entity that unfolds itself in time or it is the instantaneous boundary of such an entity"@en .

bfo:BFO_0000004 a owl:Class ;
    rdfs:label "unabhängige Kontinuante"@de,
        "independent continuant"@en ;
    rdfs:isDefinedBy <http://purl.obolibrary.org/obo/bfo/2020/bfo-core.owl> ;
    skos:definition "Kontinuante, die weder spezifisch noch generisch von einer anderen Entität abhängig ist"@de,
        "continuant that is not specifically dependent on or generically dependent on any other entity"@en .

bfo:BFO_0000029 a owl:Class ;
    rdfs:label "Ort"@de,
        "site"@en ;
    rdfs:isDefinedBy <http://purl.obolibrary.org/obo/bfo/2020/bfo-core.owl> ;
    rdfs:subClassOf bfo:BFO_0000141 ;
    skos:definition "a three-dimensional immaterial entity whose boundaries are determined by some material entity and that can be occupied by a material entity or process; used here for geographic appellations, production regions, and countries"@en .

bfo:BFO_0000141 a owl:Class ;
    rdfs:label "immaterial entity"@en ;
    rdfs:isDefinedBy <http://purl.obolibrary.org/obo/bfo/2020/bfo-core.owl> .

bfo:RO_0002234 a owl:ObjectProperty ;
    rdfs:label "hat Ausgabe"@de,
        "has output"@en ;
    rdfs:isDefinedBy bfo:ro.owl ;
    skos:definition "Beziehung zwischen einem Prozess und einer Kontinuant-Entität, die der Prozess ins Dasein bringt"@de,
        "a relation between a process and a continuant entity that the process brings into existence"@en .

eucn:AdditionalCode a owl:Class ;
    rdfs:label "Zusatzcode"@de,
        "Additional Code"@en ;
    skos:definition "vierstelliger TARIC-Code, der einem Warencode angehängt wird, um Unterkategorien für Handelsschutzmaßnahmen, besondere Verwendung oder Verbrauchsteuerzwecke anzugeben"@de,
        "four-character TARIC code appended to a commodity code to specify sub-categories for trade-remedy, authorised-use, or excise-duty purposes"@en .

eucn:Certificate a owl:Class ;
    rdfs:label "Zertifikat"@de,
        "Certificate"@en ;
    skos:definition "Handels- oder Verwaltungsdokument, das durch einen D-, C- oder Y-Präfix-Code identifiziert wird und als Bedingung für die Anwendung einer TARIC-Maßnahme erforderlich ist"@de,
        "trade or regulatory document identified by a D-, C-, or Y-prefix code required as a condition for the application of a TARIC measure"@en .

eucn:DutyExpression a owl:Class ;
    rdfs:label "Zollausdruck"@de,
        "Duty Expression"@en ;
    skos:definition "strukturierte Darstellung des im Rahmen einer TARIC-Maßnahme geltenden Zollsatzes, bestehend aus einem numerischen Betrag und seiner Maßeinheit"@de,
        "structured representation of the duty rate applicable under a single TARIC measure, combining a numeric amount with its unit of measurement"@en .

eucn:GeographicArea a owl:Class ;
    rdfs:label "Geografisches Gebiet"@de,
        "Geographic Area"@en ;
    skos:definition "benannte Instanz, die ein Land, eine Zollunion, einen Handelsblock oder die Sammelbezeichnung ERGA OMNES (Code 1011) repräsentiert, die den geografischen Geltungsbereich einer TARIC-Maßnahme bestimmt"@de,
        "named individual representing a country, customs union, trade bloc, or the catch-all designation ERGA OMNES (code 1011) that delimits the geographic scope of a TARIC measure"@en .

eucn:Heading a owl:Class ;
    rdfs:label "Position"@de,
        "Heading"@en ;
    skos:definition "vierstellige Unterteilung der Nomenklatur des Harmonisierten Systems, die eine bestimmte Warengruppe innerhalb eines Kapitels durch weitere Differenzierung nach Material, Verarbeitungsstufe oder Verwendungszweck identifiziert"@de,
        "four-digit subdivision of the Harmonized System nomenclature that identifies a specific group of goods within a chapter by further differentiating on material, process, or use"@en .

eucn:MeasureType a owl:Class ;
    rdfs:label "Maßnahmetyp"@de,
        "Measure Type"@en ;
    skos:definition "Controlled-Vocabulary-Instanz, die die Regelungskategorie einer TARIC-Maßnahme identifiziert, z. B. Drittlandszollsatz (103), Zollpräferenz (142) oder Genehmigungspflicht (750)"@de,
        "controlled-vocabulary individual identifying the regulatory category of a TARIC measure, such as third-country duty (103), tariff preference (142), or licence condition (750)"@en .

eucn:MeasurementUnit a owl:Class ;
    rdfs:label "Maßeinheit"@de,
        "Measurement Unit"@en ;
    skos:definition "Einheit, die in einem TARIC-Zollausdruck oder einer Maßnahmebedingung verwendet wird, z. B. ASV (Volumenprozent), HLT (Hektoliter) oder SPR (Standardalkoholgehalt in Prozent)"@de,
        "unit used in a TARIC duty expression or measure condition, such as ASV (percentage by volume), HLT (hectolitre), or SPR (standard percentage of alcohol)"@en .

eucn:Regulation a owl:Class ;
    rdfs:label "Verordnung"@de,
        "Regulation"@en ;
    skos:definition "EU-Verordnung, -Beschluss oder -Richtlinie, die eine oder mehrere TARIC-Maßnahmen erlässt oder ändert, identifiziert durch ihre Amtsblatt-Fundstelle"@de,
        "EU Regulation, Decision, or Directive that creates or amends one or more TARIC measures, identified by its official journal reference"@en .

eucn:TARICSection a owl:Class ;
    rdfs:label "TARIC-Abschnitt"@de,
        "TARIC Section"@en ;
    skos:definition "Gliederungsebene mit römischer Nummerierung im TARIC und Harmonisierten System, die verwandte Kapitel unter einem gemeinsamen Thema zusammenfasst"@de,
        "Roman-numeral top-level grouping in the TARIC and Harmonized System nomenclature that aggregates related chapters under a common thematic heading"@en .

bfo:BFO_0000015 a owl:Class ;
    rdfs:label "Prozess"@de,
        "process"@en ;
    rdfs:isDefinedBy <http://purl.obolibrary.org/obo/bfo/2020/bfo-core.owl> ;
    rdfs:subClassOf bfo:BFO_0000003 ;
    skos:definition "Entität, die in der Zeit durch Geschehen oder Stattfinden existiert und zeitliche Teile hat"@de,
        "entity that exists in time by occurring or happening, and that has temporal parts"@en .

bfo:RO_0000086 a owl:ObjectProperty ;
    rdfs:label "hat Eigenschaft"@de,
        "has quality"@en ;
    rdfs:domain bfo:BFO_0000030 ;
    rdfs:isDefinedBy bfo:ro.owl ;
    skos:definition "a relation between an independent continuant and a quality that it bears"@en .

eucn:Chapter a owl:Class ;
    rdfs:label "Kapitel"@de,
        "Chapter"@en ;
    skos:definition "zweistellige Unterteilung der Nomenklatur des Harmonisierten Systems, die Waren mit gemeinsamer Materialzusammensetzung, funktionaler Kategorie oder industriellem Ursprung zusammenfasst"@de,
        "two-digit subdivision of the Harmonized System nomenclature that groups goods sharing a common material composition, functional category, or industrial origin"@en .

eucn:MeasureCondition a owl:Class ;
    rdfs:label "Maßnahmebedingung"@de,
        "Measure Condition"@en ;
    skos:definition "Voraussetzung oder Einschränkung einer TARIC-Maßnahme, die ein vorzulegendes Zertifikat, einen einzuhaltenden Mengenschwellenwert oder eine Ausnahmeklausel festlegt"@de,
        "prerequisite or restriction attached to a TARIC measure specifying a certificate to be presented, a quantity threshold to be observed, or an exemption clause"@en .

eucn:Packaging a owl:Class ;
    rdfs:label "Verpackung"@de,
        "packaging"@en ;
    rdfs:subClassOf bfo:BFO_0000030 ;
    skos:definition "Eine materielle Entität, die als Behälter oder Verpackung eines Produkts dient."@de,
        "A material entity that serves as the container or packaging of a product."@en .

eucn:inLitres a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "in Litern"@de,
        "in litres"@en ;
    rdfs:domain eucn:Volume ;
    rdfs:range xsd:decimal ;
    skos:definition "the numeric volume value in litres of a Volume quality individual"@en .

eucn:ClassificationNode a owl:Class ;
    rdfs:label "Einreihungsknoten"@de,
        "Classification Node"@en ;
    skos:definition "Schritt in einem sequenziellen Wareneinreihungsverfahren, der eine einzelne unterscheidende Frage stellt, um die zutreffende Nomenklaturposition einzugrenzen; bezogen auf den Beratungsassistenten EZT-Online und ohne rechtsbindende Wirkung als EU-Instrument"@de,
        "step in a sequential commodity classification procedure that poses a single discriminating question to narrow the applicable nomenclature position; sourced from the EZT-Online advisory wizard and carrying advisory status only, not constituting a legally binding EU instrument"@en .

eucn:Volume a owl:Class ;
    rdfs:label "Volumen"@de,
        "volume"@en ;
    rdfs:subClassOf bfo:BFO_0000019 ;
    skos:definition "Eine Eigenschaft einer Verpackungsentität, die ihre Kapazität in Litern angibt."@de,
        "A quality of a packaging entity that represents its capacity, measured in litres."@en .

bfo:BFO_0000030 a owl:Class ;
    rdfs:label "Objekt"@de,
        "object"@en ;
    rdfs:isDefinedBy <http://purl.obolibrary.org/obo/bfo/2020/bfo-core.owl> ;
    rdfs:subClassOf bfo:BFO_0000004 ;
    skos:definition "dreidimensionale materielle Entität, die räumlich zusammenhängend ist und kein kontinuierender Teil einer anderen materiellen Entität ist"@de,
        "three-dimensional material entity that is spatially self-connected and is not a continuant part of any other material entity"@en .

eucn:CNCode a owl:Class ;
    rdfs:label "KN-Code"@de,
        "CN Code"@en ;
    skos:definition "Warenpositionsnummer aus acht Stellen, die innerhalb der Kombinierten Nomenklatur der Europäischen Union zur Einreihung von Waren im internationalen Handel vergeben wird"@de,
        "commodity nomenclature code of eight digits assigned within the Combined Nomenclature of the European Union for the classification of goods in international trade"@en .

eucn:TARICMeasure a owl:Class ;
    rdfs:label "TARIC-Maßnahme"@de,
        "TARIC Measure"@en ;
    skos:definition "Regelungsinstrument des Integrierten Zolltarifs der Europäischen Gemeinschaften, das einen Zollsatz, eine Beschränkung, eine Aussetzung, ein Kontingent oder eine Genehmigungspflicht für Waren festlegt, die durch einen KN- oder TARIC-Code identifiziert werden, gültig innerhalb eines bestimmten geografischen und zeitlichen Geltungsbereichs"@de,
        "regulatory instrument of the Integrated Tariff of the European Communities that specifies a tariff rate, restriction, suspension, quota, or licensing condition applicable to goods identified by a CN or TARIC code, valid within a defined geographical and temporal scope"@en .

