PREFIX owl:  <http://www.w3.org/2002/07/owl#>
PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX xsd:  <http://www.w3.org/2001/XMLSchema#>
PREFIX obo:  <http://purl.obolibrary.org/obo/>
PREFIX eucn: <https://w3id.org/eucn/>
PREFIX demo: <https://w3id.org/eucn/demo/>

<https://w3id.org/eucn/demo>
    a owl:Ontology ;
    owl:imports <https://raw.githubusercontent.com/ThHanke/eu-customs-ontology/refs/heads/main/data/ontology/eucn-ch22-beverages-latest.ttl> .

# ── ABox: beverage product individuals ────────────────────────────────────────
# Individuals are explicitly typed as the most-specific agent-defined subclass.
# The reasoner infers membership in all superclasses (subClassOf transitivity).

# CN 2204 10 — SparklingWine (agent-defined)
demo:champagne-brut a owl:NamedIndividual, eucn:SparklingWine .

# CN 2204 — WineOfFreshGrapes (agent-defined)
demo:bordeaux-rouge a owl:NamedIndividual, eucn:WineOfFreshGrapes .

# CN 2204 — FortifiedWine subClassOf WineOfFreshGrapes
demo:port-wine a owl:NamedIndividual, eucn:FortifiedWine .

# CN 2205 — AromatizedWine2205 subClassOf WineOfFreshGrapes
demo:dry-vermouth a owl:NamedIndividual, eucn:AromatizedWine2205 .

# CN 2206 — OtherFermentedBeverage2206 (agent-defined)
demo:apple-cider a owl:NamedIndividual, eucn:OtherFermentedBeverage2206 .

# CN 2202 — NonAlcoholicBeverage (agent-defined)
demo:sparkling-lemonade a owl:NamedIndividual, eucn:NonAlcoholicBeverage .

# CN 2208 — SpiritousBeverage2208 (agent-defined)
demo:whisky-12y a owl:NamedIndividual, eucn:SpiritousBeverage2208 .

# CN 2208 05 11 — GinSmallContainer22085011 subClassOf Gin subClassOf SpiritousBeverage2208
demo:gin-small a owl:NamedIndividual, eucn:GinSmallContainer22085011 .

# CN 2208 05 19 — GinLargeContainer22085019 subClassOf Gin subClassOf SpiritousBeverage2208
demo:gin-large a owl:NamedIndividual, eucn:GinLargeContainer22085019 .

# CN 2209 11 — WineVinegarSmallContainer22090011 subClassOf WineVinegar
demo:wine-vinegar-small a owl:NamedIndividual, eucn:WineVinegarSmallContainer22090011 .

# ── ABox: packaging individuals (demonstrate equivalence axiom inference) ──────
# SmallContainer ≡ Packaging ⊓ (hasQuality some (Volume ⊓ inLitres < 2.0))
# → demo:bottle-075 should be inferred as eucn:SmallContainer

demo:vol-075 a owl:NamedIndividual, eucn:Volume ;
    eucn:inLitres "0.75"^^xsd:decimal .

demo:bottle-075 a owl:NamedIndividual, eucn:Packaging ;
    obo:RO_0000086 demo:vol-075 .

# LargeContainer ≡ Packaging ⊓ (hasQuality some (Volume ⊓ inLitres ≥ 2.0))
# → demo:keg-20 should be inferred as eucn:LargeContainer

demo:vol-20 a owl:NamedIndividual, eucn:Volume ;
    eucn:inLitres "20.0"^^xsd:decimal .

demo:keg-20 a owl:NamedIndividual, eucn:Packaging ;
    obo:RO_0000086 demo:vol-20 .
