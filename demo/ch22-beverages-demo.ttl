PREFIX bfo: <http://purl.obolibrary.org/obo/>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX demo: <https://w3id.org/eucn/demo/>
PREFIX eucn: <https://w3id.org/eucn/>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX vann: <http://purl.org/vocab/vann/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

<https://w3id.org/eucn>
    a owl:Ontology ;
    rdfs:label
        "Ontologie der EU-Kombinierten Nomenklatur (KN/TARIC)"@de ,
        "EU Customs Combined Nomenclature Ontology"@en ;
    dcterms:description
        "OWL-2-DL-Ontologie zur Modellierung der Kombinierten Nomenklatur (KN) der EU und des integrierten TARIC-Zolltarifs: Warenpositionen, Zollmaßnahmen und Einreihungshilfen aus EZT-Online. Einreihungspfade aus EZT-Online haben nur Beratungscharakter und stellen kein rechtsverbindliches EU-Instrument dar."@de ,
        "OWL 2 DL ontology modelling the EU Combined Nomenclature (CN) and TARIC integrated tariff: commodity codes, duty measures, and EZT-Online classification guidance. Data extracted from the European Commission CIRCABC TARIC & Quota space. Classification paths sourced from the EZT-Online advisory wizard carry advisory status only and do not constitute legally binding EU instruments."@en ;
    dcterms:issued "2026-06-08"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:source
        <https://circabc.europa.eu/ui/group/0e5f18c2-4b2f-42e9-aed4-dfe50ae1263b> ,
        <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:31987R2658> ;
    dcterms:title
        "Ontologie der EU-Kombinierten Nomenklatur (KN/TARIC)"@de ,
        "EU Customs Combined Nomenclature Ontology"@en ;
    vann:preferredNamespacePrefix "eucn" ;
    vann:preferredNamespaceUri "https://w3id.org/eucn/" ;
    owl:versionIRI <https://w3id.org/eucn/2026/06/08> ;
    owl:versionInfo "TARIC extract 2026-06-08" ;
.

eucn:Heading
    a owl:Class ;
    rdfs:label
        "Position"@de ,
        "Heading"@en ;
    skos:definition
        "vierstellige Unterteilung der Nomenklatur des Harmonisierten Systems, die eine bestimmte Warengruppe innerhalb eines Kapitels durch weitere Differenzierung nach Material, Verarbeitungsstufe oder Verwendungszweck identifiziert"@de ,
        "four-digit subdivision of the Harmonized System nomenclature that identifies a specific group of goods within a chapter by further differentiating on material, process, or use"@en ;
.

eucn:TARICCode
    a owl:Class ;
    rdfs:label
        "TARIC-Code"@de ,
        "TARIC Code"@en ;
    rdfs:subClassOf eucn:CNCode ;
    skos:definition
        "Zehnstellige Erweiterung eines KN-Codes im Integrierten Zolltarif der Europäischen Gemeinschaften, die die anwendbaren Regelungsmaßnahmen auf der detailliertesten Warenebene festlegt"@de ,
        "ten-digit extension of a CN code within the Integrated Tariff of the European Communities that specifies the applicable regulatory measures at the most granular commodity level"@en ;
.

eucn:answerText
    a owl:DatatypeProperty ;
    rdfs:label
        "Antworttext"@de ,
        "answer text"@en ;
    rdfs:range xsd:string ;
    skos:definition
        "textliche Formulierung der Antwortoption, die bei Auswahl an einem übergeordneten Einreihungsknoten den Übergang zu diesem Einreihungsknoten im sequenziellen Einreihungsverfahren bestimmt"@de ,
        "textual formulation of the answer option that, when selected at a parent classification node, determines the transition to this classification node in the sequential classification procedure"@en ;
.

eucn:belongsToChapter
    a owl:ObjectProperty ;
    rdfs:label
        "gehört zu Kapitel"@de ,
        "belongs to chapter"@en ;
    rdfs:domain eucn:CNCode ;
    rdfs:range eucn:Chapter ;
    skos:definition
        "Beziehung zwischen einem KN-Code und dem zweistelligen Kapitel des Harmonisierten Systems, in dessen Nomenklaturgeltungsbereich der Code fällt"@de ,
        "relation between a CN code and the two-digit Harmonized System chapter in whose nomenclature scope the code is situated"@en ;
.

eucn:classifiesAs
    a owl:ObjectProperty ;
    rdfs:label
        "wird eingereiht als"@de ,
        "classifies as"@en ;
    rdfs:domain eucn:ClassificationNode ;
    rdfs:range eucn:CNCode ;
    skos:definition
        "Beziehung zwischen einem terminalen Einreihungsknoten und dem KN-Code, unter den Waren nach Abschluss des sequenziellen Einreihungsverfahrens, das am Wurzelknoten beginnt, eingereiht werden"@de ,
        "relation between a terminal classification node and the CN code to which goods are assigned upon completion of the sequential classification procedure initiated at the root node"@en ;
.

eucn:codeString
    a owl:DatatypeProperty ;
    rdfs:label
        "Codenummer"@de ,
        "code string"@en ;
    rdfs:range xsd:string ;
    skos:definition
        "Ziffernfolge, die eine Nomenklaturstelle ohne Trennzeichen eindeutig identifiziert, gebildet durch Aneinanderreihung der numerischen Segmente des Codes, z. B. '22042100' für KN-Code 2204 21 00"@de ,
        "digit string uniquely identifying a nomenclature position without separating punctuation, derived by concatenating the numeric segments of the code, e.g. '22042100' for CN code 2204 21 00"@en ;
.

demo:apple-cider
    a owl:NamedIndividual ;
    eucn:producedBy eucn:fruit-fermentation ;
.

demo:bordeaux-rouge
    a owl:NamedIndividual ;
    eucn:isCarbonated false ;
    eucn:producedBy eucn:grape-fermentation ;
.

demo:champagne-brut
    a owl:NamedIndividual ;
    eucn:isCarbonated true ;
    eucn:producedBy eucn:grape-fermentation ;
.

demo:czech-lager
    a owl:NamedIndividual ;
    eucn:alcoholByVolumePercent 5.0 ;
    eucn:producedBy eucn:malt-fermentation ;
.

demo:dry-vermouth
    a owl:NamedIndividual ;
    eucn:producedBy eucn:grape-flavouring ;
.

demo:grain-spirit-96
    a owl:NamedIndividual ;
    eucn:alcoholByVolumePercent 96.0 ;
    eucn:producedBy eucn:grain-distillation ;
.

demo:malt-vinegar
    a owl:NamedIndividual ;
    eucn:producedBy eucn:acetic-fermentation ;
.

demo:sparkling-lemonade
    a owl:NamedIndividual ;
    eucn:producedBy eucn:sweetened-water-process ;
.

demo:still-water
    a owl:NamedIndividual ;
    eucn:alcoholByVolumePercent 0.0 ;
.

demo:whisky-12y
    a owl:NamedIndividual ;
    eucn:alcoholByVolumePercent 43.0 ;
    eucn:producedBy eucn:grain-distillation ;
.

eucn:description
    a owl:DatatypeProperty ;
    rdfs:label
        "Warenbezeichnung"@de ,
        "description"@en ;
    rdfs:range xsd:string ;
    skos:definition
        "amtliche Warenbezeichnung, wie sie im Rechtstext der Kombinierten Nomenklatur festgelegt ist, in einer bestimmten natürlichen Sprache und mit rechtlicher Wirkung innerhalb der EU-Zolleinreihung"@de ,
        "official textual designation of a commodity as established in the legal text of the Combined Nomenclature, expressed in a specified natural language and carrying legal force within EU customs classification"@en ;
.

eucn:dutyAmount
    a owl:DatatypeProperty ;
    rdfs:label
        "Zollbetrag"@de ,
        "duty amount"@en ;
    rdfs:range xsd:decimal ;
    skos:definition
        "numerischer Wert des Zoll- oder Abgabensatzes im Rahmen einer TARIC-Maßnahme"@de ,
        "numeric value of the duty or charge rate applicable under a TARIC measure"@en ;
.

eucn:dutyRate
    a owl:DatatypeProperty ;
    rdfs:label
        "Zollsatz"@de ,
        "duty rate"@en ;
    rdfs:range xsd:string ;
    skos:definition
        "textliche Darstellung des Zoll- oder Abgabensatzes, der im Rahmen einer TARIC-Maßnahme gilt, wie in den TARIC-Massendaten veröffentlicht, bestehend aus einem numerischen Wert und einer Maßeinheit, z. B. '12,0 %' oder '32,0 EUR/hl'"@de ,
        "textual expression of the duty or charge rate applicable under a TARIC measure as published in the TARIC bulk data, combining a numeric value with a unit of measurement, e.g. '12.0 %' or '32.0 EUR/hl'"@en ;
.

eucn:geographicScope
    a owl:DatatypeProperty ;
    rdfs:label
        "geografischer Geltungsbereich"@de ,
        "geographic scope"@en ;
    rdfs:range xsd:string ;
    skos:definition
        "Kennung des Landes oder der Ländergruppe, deren Ursprungswaren einer TARIC-Maßnahme unterliegen, ausgedrückt als ISO 3166-1-Alpha-2-Ländercode oder als TARIC-Gruppencode, z. B. '1011' für ERGA OMNES (alle Drittländer)"@de ,
        "identifier of the country or country group to whose originating goods a TARIC measure applies, expressed as an ISO 3166-1 alpha-2 country code or a TARIC-assigned group code, e.g. '1011' for ERGA OMNES (all third countries)"@en ;
.

eucn:hasAnswer
    a owl:ObjectProperty ;
    rdfs:label
        "hat Antwort"@de ,
        "has answer"@en ;
    rdfs:domain eucn:ClassificationNode ;
    rdfs:range eucn:ClassificationNode ;
    skos:definition
        "Beziehung zwischen einem Einreihungsknoten und einem nachfolgenden Einreihungsknoten, der durch Auswahl einer bestimmten Antwort auf die am Ausgangsknoten gestellte unterscheidende Frage erreicht wird"@de ,
        "relation between a classification node and a subsequent classification node reached by selecting a particular answer to the discriminating question posed at the source node"@en ;
.

eucn:hasMeasure
    a owl:ObjectProperty ;
    rdfs:label
        "hat Maßnahme"@de ,
        "has measure"@en ;
    rdfs:domain eucn:CNCode ;
    rdfs:range eucn:TARICMeasure ;
    skos:definition
        "Beziehung zwischen einem KN-Code und einer TARIC-Maßnahme, deren Regelungsbedingungen für Waren gelten, die unter diesen KN-Code eingereiht sind"@de ,
        "relation between a CN code and a TARIC measure under which goods classified by that CN code are subject to the regulatory conditions specified by the measure"@en ;
.

eucn:isDenatured
    a owl:DatatypeProperty ;
    rdfs:label
        "ist vergällt"@de ,
        "is denatured"@en ;
    rdfs:range xsd:boolean ;
    skos:definition
        "boolesches Merkmal, das angibt, ob Ethylalkohol durch Zusatz von Stoffen vergällt wurde, die ihn für den menschlichen Genuss ungeeignet machen, zur Unterscheidung zwischen den KN-Unterpositionen 2207 10 (unvergällt) und 2207 20 (vergällt)"@de ,
        "boolean flag indicating whether ethyl alcohol has been denatured by addition of substances rendering it unfit for human consumption, used to discriminate between CN subheadings 2207 10 (undenatured) and 2207 20 (denatured)"@en ;
.

eucn:maxContainerVolumeL
    a owl:DatatypeProperty ;
    rdfs:label
        "maximales Behältervolumen in Litern"@de ,
        "maximum container volume in litres"@en ;
    rdfs:range xsd:decimal ;
    skos:definition
        "Nennvolumen in Litern des Behälters, in dem ein Getränk aufgemacht ist, zur Unterscheidung zwischen den KN-Unterpositionen 2204 21 (≤ 2 L) und 2204 29 (> 2 L)"@de ,
        "nominal volume in litres of the container in which a beverage is presented, used to discriminate between CN subheadings 2204 21 (≤ 2 L) and 2204 29 (> 2 L)"@en ;
.

eucn:measureTypeId
    a owl:DatatypeProperty ;
    rdfs:label
        "Maßnahmetyp-Kennung"@de ,
        "measure type ID"@en ;
    rdfs:range xsd:string ;
    skos:definition
        "von TARIC zugewiesener numerischer Code, der die Regelungskategorie einer Maßnahme bezeichnet und zwischen Zollarten, Verboten, Aussetzungen, Kontingenten und Genehmigungspflichten unterscheidet, z. B. '103' für den Meistbegünstigungs-Wertzollsatz"@de ,
        "numeric code assigned by TARIC that designates the regulatory category of a measure, distinguishing between duty types, prohibitions, suspensions, quotas, and licence requirements, e.g. '103' for Most Favoured Nation ad-valorem duty"@en ;
.

eucn:questionText
    a owl:DatatypeProperty ;
    rdfs:label
        "Fragetext"@de ,
        "question text"@en ;
    rdfs:range xsd:string ;
    skos:definition
        "textliche Formulierung der unterscheidenden Frage, die an einem Einreihungsknoten des EZT-Online-Assistenten gestellt wird, in einer bestimmten natürlichen Sprache, zur Führung des Einreihenden zur zutreffenden Nomenklaturstelle"@de ,
        "textual formulation of the discriminating question posed at a classification node in the EZT-Online wizard, expressed in a specified natural language, used to guide the classifier toward the applicable nomenclature branch"@en ;
.

eucn:regulationId
    a owl:DatatypeProperty ;
    rdfs:label
        "Verordnungskennung"@de ,
        "regulation ID"@en ;
    rdfs:range xsd:string ;
    skos:definition
        "Kennung der EU-Verordnung oder der maßnahmenerzeugenden Verordnung, die eine TARIC-Maßnahme erlassen oder zuletzt geändert hat"@de ,
        "identifier of the EU regulation or measure generating regulation that created or last amended a TARIC measure"@en ;
.

eucn:validityEnd
    a owl:DatatypeProperty ;
    rdfs:label
        "Gültigkeitsende"@de ,
        "validity end"@en ;
    rdfs:range xsd:date ;
    skos:definition
        "Datum, an dem eine TARIC-Maßnahme außer Kraft tritt; fehlt, wenn die Maßnahme kein festgelegtes Ablaufdatum hat"@de ,
        "date on which a TARIC measure ceases to be in force; absent when the measure has no fixed expiry"@en ;
.

eucn:validityStart
    a owl:DatatypeProperty ;
    rdfs:label
        "Gültigkeitsbeginn"@de ,
        "validity start"@en ;
    rdfs:range xsd:date ;
    skos:definition
        "Datum, ab dem eine TARIC-Maßnahme in Kraft tritt"@de ,
        "date from which a TARIC measure is in force"@en ;
.

bfo:BFO_0000030
    a owl:Class ;
    rdfs:label
        "Objekt"@de ,
        "object"@en ;
    rdfs:isDefinedBy <http://purl.obolibrary.org/obo/bfo/2020/bfo-core.owl> ;
    skos:definition
        "dreidimensionale materielle Entität, die räumlich zusammenhängend ist und kein kontinuierender Teil einer anderen materiellen Entität ist"@de ,
        "three-dimensional material entity that is spatially self-connected and is not a continuant part of any other material entity"@en ;
.

bfo:RO_0002234
    a owl:ObjectProperty ;
    rdfs:label
        "hat Ausgabe"@de ,
        "has output"@en ;
    rdfs:isDefinedBy bfo:ro.owl ;
    skos:definition
        "Beziehung zwischen einem Prozess und einer Kontinuant-Entität, die der Prozess ins Dasein bringt"@de ,
        "a relation between a process and a continuant entity that the process brings into existence"@en ;
.

eucn:Chapter
    a owl:Class ;
    rdfs:label
        "Kapitel"@de ,
        "Chapter"@en ;
    skos:definition
        "zweistellige Unterteilung der Nomenklatur des Harmonisierten Systems, die Waren mit gemeinsamer Materialzusammensetzung, funktionaler Kategorie oder industriellem Ursprung zusammenfasst"@de ,
        "two-digit subdivision of the Harmonized System nomenclature that groups goods sharing a common material composition, functional category, or industrial origin"@en ;
.

eucn:TARICMeasure
    a owl:Class ;
    rdfs:label
        "TARIC-Maßnahme"@de ,
        "TARIC Measure"@en ;
    skos:definition
        "Regelungsinstrument des Integrierten Zolltarifs der Europäischen Gemeinschaften, das einen Zollsatz, eine Beschränkung, eine Aussetzung, ein Kontingent oder eine Genehmigungspflicht für Waren festlegt, die durch einen KN- oder TARIC-Code identifiziert werden, gültig innerhalb eines bestimmten geografischen und zeitlichen Geltungsbereichs"@de ,
        "regulatory instrument of the Integrated Tariff of the European Communities that specifies a tariff rate, restriction, suspension, quota, or licensing condition applicable to goods identified by a CN or TARIC code, valid within a defined geographical and temporal scope"@en ;
.

eucn:GrapeMust
    a owl:Class ;
    rdfs:label
        "Traubenmost"@de ,
        "Grape Must"@en ;
    rdfs:subClassOf eucn:Wine ;
    owl:disjointWith
        eucn:SparklingWine ,
        eucn:StillWine ;
    skos:definition
        "Traubenmost, dessen Gärung durch Alkoholzusatz unterbrochen wurde, eingereiht in KN-Unterposition 2204 30 (Kapitel 22)"@de ,
        "grape must with fermentation arrested by the addition of alcohol, classified under CN subheading 2204 30 (Chapter 22)"@en ;
.

eucn:SparklingWine
    a owl:Class ;
    rdfs:label
        "Schaumwein"@de ,
        "Sparkling Wine"@en ;
    rdfs:subClassOf eucn:Wine ;
    owl:disjointWith
        eucn:GrapeMust ,
        eucn:StillWine ;
    owl:equivalentClass
        [
            a owl:Class ;
            owl:intersectionOf (
                
                [
                    a owl:Restriction ;
                    owl:hasValue eucn:grape-fermentation ;
                    owl:onProperty eucn:producedBy ;
                ]
                
                [
                    a owl:Restriction ;
                    owl:hasValue true ;
                    owl:onProperty eucn:isCarbonated ;
                ]
            ) ;
        ] ;
    skos:definition
        "Wein aus frischen Weintrauben, der durch Zusatz von Kohlendioxid oder durch Flaschengärung schäumend ist, eingereiht in KN-Unterposition 2204 10 (Kapitel 22)"@de ,
        "wine of fresh grapes that is effervescent by reason of the addition of carbon dioxide or by secondary fermentation in bottle, classified under CN subheading 2204 10 (Chapter 22)"@en ;
.

eucn:StillWine
    a owl:Class ;
    rdfs:label
        "Stillwein"@de ,
        "Still Wine"@en ;
    rdfs:subClassOf eucn:Wine ;
    owl:disjointWith
        eucn:GrapeMust ,
        eucn:SparklingWine ;
    owl:equivalentClass
        [
            a owl:Class ;
            owl:intersectionOf (
                
                [
                    a owl:Restriction ;
                    owl:hasValue eucn:grape-fermentation ;
                    owl:onProperty eucn:producedBy ;
                ]
                
                [
                    a owl:Restriction ;
                    owl:hasValue false ;
                    owl:onProperty eucn:isCarbonated ;
                ]
            ) ;
        ] ;
    skos:definition
        "Nicht schäumender Wein aus frischen Weintrauben in Behältnissen, eingereiht in KN-Unterpositionen 2204 21 (≤ 2 L) und 2204 29 (> 2 L) (Kapitel 22)"@de ,
        "non-sparkling wine of fresh grapes in containers, classified under CN subheadings 2204 21 (≤ 2 L) and 2204 29 (> 2 L) (Chapter 22)"@en ;
.

eucn:isCarbonated
    a owl:DatatypeProperty ;
    rdfs:label
        "ist kohlensäurehaltig"@de ,
        "is carbonated"@en ;
    rdfs:range xsd:boolean ;
    skos:definition
        "boolesches Merkmal, das angibt, ob ein Getränk mit Kohlensäure versetzt (schäumend) statt still ist, zur Unterscheidung zwischen den KN-Unterpositionen 2204 10 und 2204 21/29"@de ,
        "boolean flag indicating whether a beverage is carbonated (sparkling) rather than still, used to discriminate between CN subheadings 2204 10 (sparkling) and 2204 21/29 (still)"@en ;
.

eucn:ClassificationNode
    a owl:Class ;
    rdfs:label
        "Einreihungsknoten"@de ,
        "Classification Node"@en ;
    skos:definition
        "Schritt in einem sequenziellen Wareneinreihungsverfahren, der eine einzelne unterscheidende Frage stellt, um die zutreffende Nomenklaturposition einzugrenzen; bezogen auf den Beratungsassistenten EZT-Online und ohne rechtsbindende Wirkung als EU-Instrument"@de ,
        "step in a sequential commodity classification procedure that poses a single discriminating question to narrow the applicable nomenclature position; sourced from the EZT-Online advisory wizard and carrying advisory status only, not constituting a legally binding EU instrument"@en ;
.

eucn:CNCode
    a owl:Class ;
    rdfs:label
        "KN-Code"@de ,
        "CN Code"@en ;
    skos:definition
        "Warenpositionsnummer aus acht Stellen, die innerhalb der Kombinierten Nomenklatur der Europäischen Union zur Einreihung von Waren im internationalen Handel vergeben wird"@de ,
        "commodity nomenclature code of eight digits assigned within the Combined Nomenclature of the European Union for the classification of goods in international trade"@en ;
.

eucn:alcoholByVolumePercent
    a owl:DatatypeProperty ;
    rdfs:label
        "Alkoholgehalt in Volumenprozent"@de ,
        "alcohol by volume percent"@en ;
    rdfs:range xsd:decimal ;
    skos:definition
        "Alkoholgehalt eines Getränks, ausgedrückt als Volumenprozent, zur Unterscheidung zwischen den KN-Positionen 2201–2208 in Kapitel 22"@de ,
        "alcohol content of a beverage expressed as a percentage of volume, used to discriminate between CN headings 2201–2208 in Chapter 22"@en ;
.

eucn:AceticFermentation
    a owl:Class ;
    rdfs:label
        "Essigsäuregärung"@de ,
        "acetic fermentation"@en ;
    rdfs:subClassOf bfo:BFO_0000015 ;
    owl:disjointWith
        eucn:FruitFermentation ,
        eucn:GrainDistillation ,
        eucn:GrapeFermentation ,
        eucn:GrapeFlavouringProcess ,
        eucn:MaltFermentation ,
        eucn:SweetenedWaterProcess ;
    skos:definition
        "Prozess der Essigsäuregärung von Ethylalkohol zur Herstellung von Essig; jedes Individuum repräsentiert den einzigartigen Essigsäuregärungsprozesstyp in der KN-Kapitel-22-Einreihung"@de ,
        "process of acetic acid fermentation of ethyl alcohol to produce vinegar; each individual represents the unique acetic-fermentation process type in the CN Chapter 22 classification"@en ;
.

eucn:FruitFermentation
    a owl:Class ;
    rdfs:label
        "Fruchtfermentation"@de ,
        "fruit fermentation"@en ;
    rdfs:subClassOf bfo:BFO_0000015 ;
    owl:disjointWith
        eucn:AceticFermentation ,
        eucn:GrainDistillation ,
        eucn:GrapeFermentation ,
        eucn:GrapeFlavouringProcess ,
        eucn:MaltFermentation ,
        eucn:SweetenedWaterProcess ;
    skos:definition
        "Prozess der Vergärung von Früchten (außer Weintrauben) zur Herstellung von Apfelwein, Birnenwein oder anderen Gärerzeugnissen; jedes Individuum repräsentiert den einzigartigen Fruchtfermentationsprozesstyp in der KN-Kapitel-22-Einreihung"@de ,
        "process of fermenting fruit (other than grapes) to produce cider, perry, or other fermented beverages; each individual represents the unique fruit-fermentation process type in the CN Chapter 22 classification"@en ;
.

eucn:GrainDistillation
    a owl:Class ;
    rdfs:label
        "Getreidebrennerei"@de ,
        "grain distillation"@en ;
    rdfs:subClassOf bfo:BFO_0000015 ;
    owl:disjointWith
        eucn:AceticFermentation ,
        eucn:FruitFermentation ,
        eucn:GrapeFermentation ,
        eucn:GrapeFlavouringProcess ,
        eucn:MaltFermentation ,
        eucn:SweetenedWaterProcess ;
    skos:definition
        "Prozess der Destillation von vergorenem Getreidebrei zur Herstellung von Spirituosen oder hochprozentigem Ethylalkohol; jedes Individuum repräsentiert den einzigartigen Getreidedestillationsprozesstyp in der KN-Kapitel-22-Einreihung"@de ,
        "process of distilling fermented grain mash to produce spirits or high-strength ethyl alcohol; each individual represents the unique grain-distillation process type in the CN Chapter 22 classification"@en ;
.

eucn:GrapeFermentation
    a owl:Class ;
    rdfs:label
        "Traubenfermentation"@de ,
        "grape fermentation"@en ;
    rdfs:subClassOf bfo:BFO_0000015 ;
    owl:disjointWith
        eucn:AceticFermentation ,
        eucn:FruitFermentation ,
        eucn:GrainDistillation ,
        eucn:GrapeFlavouringProcess ,
        eucn:MaltFermentation ,
        eucn:SweetenedWaterProcess ;
    skos:definition
        "Prozess der Vergärung von frischen Weintrauben oder Traubenmost zur Herstellung von Wein; jedes Individuum repräsentiert den einzigartigen Traubenfermentationsprozesstyp in der KN-Kapitel-22-Einreihung"@de ,
        "process of fermenting fresh grapes or grape must to produce wine; each individual represents the unique grape-fermentation process type in the CN Chapter 22 classification"@en ;
.

eucn:GrapeFlavouringProcess
    a owl:Class ;
    rdfs:label
        "Traubenaromatisierungsprozess"@de ,
        "grape flavouring process"@en ;
    rdfs:subClassOf bfo:BFO_0000015 ;
    owl:disjointWith
        eucn:AceticFermentation ,
        eucn:FruitFermentation ,
        eucn:GrainDistillation ,
        eucn:GrapeFermentation ,
        eucn:MaltFermentation ,
        eucn:SweetenedWaterProcess ;
    skos:definition
        "Prozess der Aromatisierung von traubenbasiertem Wein mit Pflanzen oder aromatischen Stoffen zur Herstellung von Wermutein oder anderen aromatisierten Weinen; jedes Individuum repräsentiert den einzigartigen Traubenaromatisierungsprozesstyp in der KN-Kapitel-22-Einreihung"@de ,
        "process of flavouring grape-based wine with plants or aromatic substances to produce vermouth or other flavoured wines; each individual represents the unique grape-flavouring process type in the CN Chapter 22 classification"@en ;
.

eucn:MaltFermentation
    a owl:Class ;
    rdfs:label
        "Malzfermentation"@de ,
        "malt fermentation"@en ;
    rdfs:subClassOf bfo:BFO_0000015 ;
    owl:disjointWith
        eucn:AceticFermentation ,
        eucn:FruitFermentation ,
        eucn:GrainDistillation ,
        eucn:GrapeFermentation ,
        eucn:GrapeFlavouringProcess ,
        eucn:SweetenedWaterProcess ;
    skos:definition
        "Prozess der Vergärung von Gerstenmalz oder anderen Getreidearten zur Herstellung von Bier; jedes Individuum repräsentiert den einzigartigen Malzfermentationsprozesstyp in der KN-Kapitel-22-Einreihung"@de ,
        "process of fermenting malted barley or other cereals to produce beer; each individual represents the unique malt-fermentation process type in the CN Chapter 22 classification"@en ;
.

eucn:SweetenedWaterProcess
    a owl:Class ;
    rdfs:label
        "Süßwasserprozess"@de ,
        "sweetened water process"@en ;
    rdfs:subClassOf bfo:BFO_0000015 ;
    owl:disjointWith
        eucn:AceticFermentation ,
        eucn:FruitFermentation ,
        eucn:GrainDistillation ,
        eucn:GrapeFermentation ,
        eucn:GrapeFlavouringProcess ,
        eucn:MaltFermentation ;
    skos:definition
        "Prozess zur Herstellung von gesüßten oder aromatisierten nichtalkoholischen Getränken durch Zugabe von Zucker oder Aromen zu Wasser; jedes Individuum repräsentiert den einzigartigen Süßwasserprozesstyp in der KN-Kapitel-22-Einreihung"@de ,
        "process of producing sweetened or flavoured non-alcoholic beverages by adding sugar or flavouring to water; each individual represents the unique sweetened-water-process type in the CN Chapter 22 classification"@en ;
.

bfo:BFO_0000015
    a owl:Class ;
    rdfs:label
        "Prozess"@de ,
        "process"@en ;
    rdfs:isDefinedBy <http://purl.obolibrary.org/obo/bfo/2020/bfo-core.owl> ;
    skos:definition
        "Entität, die in der Zeit durch Geschehen oder Stattfinden existiert und zeitliche Teile hat"@de ,
        "entity that exists in time by occurring or happening, and that has temporal parts"@en ;
.

eucn:Beer
    a owl:Class ;
    rdfs:label
        "Bier"@de ,
        "Beer"@en ;
    rdfs:subClassOf eucn:Beverage ;
    owl:disjointWith
        eucn:EthylAlcohol ,
        eucn:FermentedBeverage ,
        eucn:FlavouredWine ,
        eucn:NonAlcoholicBeverage ,
        eucn:Spirit ,
        eucn:Vinegar ,
        eucn:Water ,
        eucn:Wine ;
    owl:equivalentClass
        [
            a owl:Class ;
            owl:intersectionOf (
                
                [
                    a owl:Restriction ;
                    owl:hasValue eucn:malt-fermentation ;
                    owl:onProperty eucn:producedBy ;
                ]
                
                [
                    a owl:Restriction ;
                    owl:onProperty eucn:alcoholByVolumePercent ;
                    owl:someValuesFrom
                        [
                            a rdfs:Datatype ;
                            owl:onDatatype xsd:decimal ;
                            owl:withRestrictions (
                                
                                [
                                    xsd:minExclusive 0.5 ;
                                ]
                            ) ;
                        ] ;
                ]
            ) ;
        ] ;
    skos:definition
        "Bier aus Malz, fermentiertes Getränk mit einem Alkoholgehalt, der durch Vergärung von Gerstenmalz oder anderen Getreidearten entsteht, eingereiht in KN-Position 2203 (Kapitel 22)"@de ,
        "beer made from malt, a fermented beverage with alcoholic strength derived from the fermentation of malted barley or other cereals, classified under CN heading 2203 (Chapter 22)"@en ;
.

eucn:EthylAlcohol
    a owl:Class ;
    rdfs:label
        "Ethylalkohol"@de ,
        "Ethyl Alcohol"@en ;
    rdfs:subClassOf eucn:Beverage ;
    owl:disjointWith
        eucn:Beer ,
        eucn:FermentedBeverage ,
        eucn:FlavouredWine ,
        eucn:NonAlcoholicBeverage ,
        eucn:Spirit ,
        eucn:Vinegar ,
        eucn:Water ,
        eucn:Wine ;
    owl:equivalentClass
        [
            a owl:Class ;
            owl:intersectionOf (
                
                [
                    a owl:Restriction ;
                    owl:onProperty eucn:alcoholByVolumePercent ;
                    owl:someValuesFrom
                        [
                            a rdfs:Datatype ;
                            owl:onDatatype xsd:decimal ;
                            owl:withRestrictions (
                                
                                [
                                    xsd:minInclusive 80.0 ;
                                ]
                            ) ;
                        ] ;
                ]
                
                [
                    a owl:Class ;
                    owl:complementOf
                        [
                            a owl:Restriction ;
                            owl:hasValue eucn:malt-fermentation ;
                            owl:onProperty eucn:producedBy ;
                        ] ;
                ]
                
                [
                    a owl:Class ;
                    owl:complementOf
                        [
                            a owl:Restriction ;
                            owl:hasValue eucn:fruit-fermentation ;
                            owl:onProperty eucn:producedBy ;
                        ] ;
                ]
                
                [
                    a owl:Class ;
                    owl:complementOf
                        [
                            a owl:Restriction ;
                            owl:hasValue eucn:grape-flavouring ;
                            owl:onProperty eucn:producedBy ;
                        ] ;
                ]
                
                [
                    a owl:Class ;
                    owl:complementOf
                        [
                            a owl:Restriction ;
                            owl:hasValue eucn:sweetened-water-process ;
                            owl:onProperty eucn:producedBy ;
                        ] ;
                ]
                
                [
                    a owl:Class ;
                    owl:complementOf
                        [
                            a owl:Restriction ;
                            owl:hasValue eucn:acetic-fermentation ;
                            owl:onProperty eucn:producedBy ;
                        ] ;
                ]
                
                [
                    a owl:Class ;
                    owl:complementOf
                        [
                            a owl:Restriction ;
                            owl:hasValue eucn:grape-fermentation ;
                            owl:onProperty eucn:producedBy ;
                        ] ;
                ]
            ) ;
        ] ;
    skos:definition
        "Unvergällter Ethylalkohol mit einem Alkoholgehalt von 80 % vol oder mehr; Ethylalkohol und andere Spirituosen, vergällt, jedes Alkoholgehalts, eingereiht in KN-Position 2207 (Kapitel 22)"@de ,
        "undenatured ethyl alcohol of an alcoholic strength by volume of 80 % vol or higher; ethyl alcohol and other spirits, denatured, of any strength, classified under CN heading 2207 (Chapter 22)"@en ;
.

eucn:FermentedBeverage
    a owl:Class ;
