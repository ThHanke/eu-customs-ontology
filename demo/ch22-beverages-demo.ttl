PREFIX owl:  <http://www.w3.org/2002/07/owl#>
PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX xsd:  <http://www.w3.org/2001/XMLSchema#>
PREFIX obo:  <http://purl.obolibrary.org/obo/>
PREFIX eucn: <https://w3id.org/eucn/>
PREFIX demo: <https://w3id.org/eucn/demo/>

<https://w3id.org/eucn/demo>
    a owl:Ontology .

# ════════════════════════════════════════════════════════════════════════
# ABox: CN classification via OWL property-based reasoning
#
# Individuals are typed as PARENT classes only. No individual is explicitly
# typed as a leaf CN class. The OWL reasoner infers leaf membership from
# property assertions (qualities + parts).
#
# Demonstrated patterns:
#   (A) SmallContainer/LargeContainer inferred from packaging volume (< 2L / ≥ 2L)
#   (B) Wine vinegar: Vinegar2209 + WineVinegarQuality + container size
#       → WineVinegarSmallContainer22090011 / WineVinegarLargeContainer22090019
#   (C) Sparkling wine: WineFreshGrapesGrapeMust2204 + SparklingWineQuality
#       + OtherSparklingWineDesignationQuality + container size
#       → OtherSparklingWineSmallContainer22041094 / OtherSparklingWineLargeContainer22041096
# ════════════════════════════════════════════════════════════════════════


# ── (A) Packaging individuals — typed as Packaging only ──────────────────
# SmallContainer ≡ Packaging ⊓ (RO:0000086 some (Volume ⊓ ∃inLitres.[< 2.0]))
# LargeContainer ≡ Packaging ⊓ (RO:0000086 some (Volume ⊓ ∃inLitres.[≥ 2.0]))

demo:vol-075 a owl:NamedIndividual, eucn:Volume ;
    eucn:inLitres "0.75"^^xsd:decimal .

demo:bottle-075 a owl:NamedIndividual, eucn:Packaging ;
    obo:RO_0000086 demo:vol-075 .
# → reasoner infers: demo:bottle-075 a eucn:SmallContainer

demo:vol-20 a owl:NamedIndividual, eucn:Volume ;
    eucn:inLitres "20.0"^^xsd:decimal .

demo:keg-20 a owl:NamedIndividual, eucn:Packaging ;
    obo:RO_0000086 demo:vol-20 .
# → reasoner infers: demo:keg-20 a eucn:LargeContainer


# ── (B) Wine vinegar — container-size discrimination ─────────────────────
# WineVinegarSmallContainer22090011 ≡ Vinegar2209 ⊓
#     (RO:0000086 some WineVinegarQuality) ⊓ (BFO:0000051 some SmallContainer)
# WineVinegarLargeContainer22090019 ≡ Vinegar2209 ⊓
#     (RO:0000086 some WineVinegarQuality) ⊓ (BFO:0000051 some LargeContainer)

demo:wine-vinegar-quality a owl:NamedIndividual, eucn:WineVinegarQuality .

demo:wine-vinegar-bottle-vol a owl:NamedIndividual, eucn:Volume ;
    eucn:inLitres "0.75"^^xsd:decimal .
demo:wine-vinegar-bottle a owl:NamedIndividual, eucn:Packaging ;
    obo:RO_0000086 demo:wine-vinegar-bottle-vol .
# → reasoner infers: demo:wine-vinegar-bottle a eucn:SmallContainer

demo:wine-vinegar-small a owl:NamedIndividual, eucn:Vinegar2209 ;
    obo:RO_0000086 demo:wine-vinegar-quality ;
    obo:BFO_0000051 demo:wine-vinegar-bottle .
# → reasoner infers: demo:wine-vinegar-small a eucn:WineVinegarSmallContainer22090011
# → transitively: a eucn:Vinegar2209, a eucn:Beverage

demo:wine-vinegar-jug-vol a owl:NamedIndividual, eucn:Volume ;
    eucn:inLitres "5.0"^^xsd:decimal .
demo:wine-vinegar-jug a owl:NamedIndividual, eucn:Packaging ;
    obo:RO_0000086 demo:wine-vinegar-jug-vol .
# → reasoner infers: demo:wine-vinegar-jug a eucn:LargeContainer

demo:wine-vinegar-large a owl:NamedIndividual, eucn:Vinegar2209 ;
    obo:RO_0000086 demo:wine-vinegar-quality ;
    obo:BFO_0000051 demo:wine-vinegar-jug .
# → reasoner infers: demo:wine-vinegar-large a eucn:WineVinegarLargeContainer22090019


# ── (C) Sparkling wine — container-size discrimination ───────────────────
# OtherSparklingWineSmallContainer22041094 ≡ WineFreshGrapesGrapeMust2204 ⊓
#     (RO:0000086 some SparklingWineQuality) ⊓
#     (RO:0000086 some OtherSparklingWineDesignationQuality) ⊓
#     (BFO:0000051 some SmallContainer)
# OtherSparklingWineLargeContainer22041096 ≡ WineFreshGrapesGrapeMust2204 ⊓
#     (RO:0000086 some SparklingWineQuality) ⊓
#     (RO:0000086 some OtherSparklingWineDesignationQuality) ⊓
#     (RO:0000086 some FreshGrapeOriginQuality) ⊓
#     (BFO:0000051 some LargeContainer)

demo:sparkling-quality a owl:NamedIndividual, eucn:SparklingWineQuality .
demo:other-sparkling-designation a owl:NamedIndividual, eucn:OtherSparklingWineDesignationQuality .
demo:fresh-grape-quality a owl:NamedIndividual, eucn:FreshGrapeOriginQuality .

demo:sparkling-bottle-vol a owl:NamedIndividual, eucn:Volume ;
    eucn:inLitres "0.75"^^xsd:decimal .
demo:sparkling-bottle a owl:NamedIndividual, eucn:Packaging ;
    obo:RO_0000086 demo:sparkling-bottle-vol .
# → reasoner infers: demo:sparkling-bottle a eucn:SmallContainer

demo:sparkling-wine-small a owl:NamedIndividual, eucn:WineFreshGrapesGrapeMust2204 ;
    obo:RO_0000086 demo:sparkling-quality ;
    obo:RO_0000086 demo:other-sparkling-designation ;
    obo:BFO_0000051 demo:sparkling-bottle .
# → reasoner infers: demo:sparkling-wine-small a eucn:OtherSparklingWineSmallContainer22041094
# → transitively: a eucn:WineFreshGrapesGrapeMust2204, a eucn:Beverage

demo:sparkling-tank-vol a owl:NamedIndividual, eucn:Volume ;
    eucn:inLitres "20.0"^^xsd:decimal .
demo:sparkling-tank a owl:NamedIndividual, eucn:Packaging ;
    obo:RO_0000086 demo:sparkling-tank-vol .
# → reasoner infers: demo:sparkling-tank a eucn:LargeContainer

demo:sparkling-wine-large a owl:NamedIndividual, eucn:WineFreshGrapesGrapeMust2204 ;
    obo:RO_0000086 demo:sparkling-quality ;
    obo:RO_0000086 demo:other-sparkling-designation ;
    obo:RO_0000086 demo:fresh-grape-quality ;
    obo:BFO_0000051 demo:sparkling-tank .
# → reasoner infers: demo:sparkling-wine-large a eucn:OtherSparklingWineLargeContainer22041096
